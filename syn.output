Terminals unused in grammar

   point


Grammar

    0 $accept: S $end

    1 S: BeginProject_mc idf point_virg SECTION_SETUP SECTION_RUN EndProject_mc point_virg

    2 SECTION_SETUP: Setup_mc deux_points LISTE_DECLARATIONS

    3 LISTE_DECLARATIONS: UNE_DECLARATION LISTE_DECLARATIONS
    4                   | /* empty */

    5 UNE_DECLARATION: DECL_DEFINE
    6                | DECL_CONSTANTE

    7 $@1: /* empty */

    8 DECL_DEFINE: define_mc idf $@1 LISTE_IDFS_SUITE deux_points SUITE_TYPE point_virg

    9 LISTE_IDFS_SUITE: barre_mc idf LISTE_IDFS_SUITE
   10                 | /* empty */

   11 SUITE_TYPE: TYPE OPT_INIT
   12           | crochet_ouvrant TYPE point_virg ENTIER crochet_fermant

   13 TYPE: int_mc
   14     | float_mc

   15 OPT_INIT: egal VALEUR
   16         | /* empty */

   17 DECL_CONSTANTE: const_mc idf deux_points TYPE egal VALEUR point_virg

   18 SECTION_RUN: Run_mc deux_points accolade_ouvrante LISTE_INSTRUCTIONS accolade_fermante

   19 LISTE_INSTRUCTIONS: UNE_INSTRUCTION LISTE_INSTRUCTIONS
   20                   | /* empty */

   21 UNE_INSTRUCTION: INSTRUCTION_AFFECTATION
   22                | INSTRUCTION_CONDITION
   23                | INSTRUCTION_BOUCLE
   24                | INSTRUCTION_IO

   25 INSTRUCTION_AFFECTATION: idf affectation EXPRESSION point_virg
   26                        | idf crochet_ouvrant ENTIER crochet_fermant affectation EXPRESSION point_virg

   27 $@2: /* empty */

   28 $@3: /* empty */

   29 INSTRUCTION_CONDITION: if_mc parenthese_ouvrante CONDITION parenthese_fermante $@2 then_mc OPT_DEUX_POINTS accolade_ouvrante LISTE_INSTRUCTIONS accolade_fermante $@3 else_mc accolade_ouvrante LISTE_INSTRUCTIONS accolade_fermante endIf_mc point_virg

   30 OPT_DEUX_POINTS: deux_points
   31                | /* empty */

   32 INSTRUCTION_BOUCLE: loop_mc while_mc parenthese_ouvrante CONDITION parenthese_fermante accolade_ouvrante LISTE_INSTRUCTIONS accolade_fermante endloop_mc point_virg
   33                   | for_mc idf in_mc VALEUR to_mc VALEUR accolade_ouvrante LISTE_INSTRUCTIONS accolade_fermante endfor_mc point_virg

   34 INSTRUCTION_IO: out_mc parenthese_ouvrante LISTE_OUT parenthese_fermante point_virg
   35               | in_mc parenthese_ouvrante idf parenthese_fermante point_virg

   36 LISTE_OUT: chaine
   37          | chaine virg idf
   38          | idf

   39 EXPRESSION: EXPRESSION addition TERME
   40           | EXPRESSION sustra TERME
   41           | TERME

   42 TERME: TERME multipl FACTEUR
   43      | TERME div_op FACTEUR
   44      | FACTEUR

   45 FACTEUR: idf
   46        | ENTIER
   47        | REEL
   48        | idf crochet_ouvrant ENTIER crochet_fermant
   49        | parenthese_ouvrante EXPRESSION parenthese_fermante

   50 CONDITION: EXPRESSION OPERATEUR_COMP EXPRESSION
   51          | parenthese_ouvrante CONDITION parenthese_fermante
   52          | CONDITION AND_mc CONDITION
   53          | CONDITION OR_mc CONDITION
   54          | NON_mc CONDITION

   55 OPERATEUR_COMP: supperieure
   56               | inferieure
   57               | sup_egal
   58               | inf_egal
   59               | egal
   60               | diff_op

   61 VALEUR: ENTIER
   62       | REEL

   63 ENTIER: cst_int
   64       | parenthese_ouvrante SIGNE cst_int parenthese_fermante

   65 REEL: cst_float
   66     | parenthese_ouvrante SIGNE cst_float parenthese_fermante

   67 SIGNE: addition
   68      | sustra


